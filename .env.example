# RotaShift — copy this file to `.env` on every machine (never commit `.env`).
# Quick start after git clone: see README → "Work from any PC".
#
# Docker (recommended):  .\start-docker.bat   or   ./start-docker.sh
# Python only:           pip install -r requirements.txt && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000

# --- Same data on every PC (MongoDB Atlas) ---
# Uncomment and set your Atlas URI so all machines see the same users/rosters.
# MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
# ROTASHIFT_DB=rotashift

# --- Local-only demo (no Atlas): leave MONGO_URI unset; Docker starts a local MongoDB volume ---

# Optional port when using Docker (default 8000)
# ROTASHIFT_PORT=8000

# Self-registration invite codes (Docker defaults if unset: MANAGER-DEV-2026 / ADMIN-DEV-2026)
ROTASHIFT_REGISTER_CODE_MANAGER=MANAGER-DEV-2026
ROTASHIFT_REGISTER_CODE_ADMIN=ADMIN-DEV-2026

# Optional — on each app startup: promote these logins to admin (if they already exist), or create them:
# ROTASHIFT_ADMIN_EMPLOYEE_ID=001,007
# ROTASHIFT_ADMIN_PASSWORD=your-initial-password   # required only for ids that do not exist yet in the database

# --- Production / scaling ---
# ROTASHIFT_ENV=production
# ROTASHIFT_SECRET_KEY=   # required strong secret when ROTASHIFT_ENV=production
# MONGO_URI=mongodb://localhost:27017
# ROTASHIFT_DB=rotashift
#
# --- Where data is stored in MongoDB ---
# All app data uses database name ROTASHIFT_DB (default: rotashift). Collections include: users, departments, shifts,
# leave_requests, shift_change_requests. In Atlas → Browse Collections, select this database — NOT only the name that
# appears in your connection string path (e.g. many Atlas URIs end with /test but the app still writes to rotashift
# unless you set ROTASHIFT_DB to match).
# MONGO_MAX_POOL_SIZE=50
# MONGO_MIN_POOL_SIZE=0
# MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
# CORS_ORIGINS=https://app.example.com,https://www.example.com
